<div class="skill-card" style="--accent-color: @AccentColor;">
    <div class="sweep-line"></div>
    <div class="card-content">
        <i class="@IconClass"></i>
        <span class="card-title">@Title</span>
        <span class="card-subtitle">@Subtitle</span>
    </div>
</div>

@code {
    [Parameter] public string IconClass { get; set; } = "fas fa-code";
    [Parameter] public string Title { get; set; } = "Skill";
    [Parameter] public string Subtitle { get; set; } = "Description";
    [Parameter] public string AccentColor { get; set; } = "#3b82f6";
}